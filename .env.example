# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Admin / Contact ────────────────────────────────────────
# Email used to identify admin (legacy fallback — now uses profiles.is_admin flag)
ADMIN_EMAIL=
# Where contact form submissions are sent
CONTACT_EMAIL=

# ─── Encryption ─────────────────────────────────────────────
# 32-byte hex key for encrypting BYOK API keys at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─── Anthropic (Claude API) ─────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Paddle Billing ─────────────────────────────────────────
PADDLE_API_KEY=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
PADDLE_WEBHOOK_SECRET=
NEXT_PUBLIC_PADDLE_ENV=sandbox
PADDLE_STARTER_MONTHLY_PRICE_ID=
PADDLE_STARTER_ANNUAL_PRICE_ID=
PADDLE_PRO_MONTHLY_PRICE_ID=
PADDLE_PRO_ANNUAL_PRICE_ID=
PADDLE_BUSINESS_MONTHLY_PRICE_ID=
PADDLE_BUSINESS_ANNUAL_PRICE_ID=

# ─── Resend (Transactional Email) ───────────────────────────
RESEND_API_KEY=

# ─── Backblaze B2 (File Storage) ────────────────────────────
B2_ACCESS_KEY_ID=
B2_SECRET_ACCESS_KEY=
B2_BUCKET_NAME=
B2_ENDPOINT=
B2_REGION=us-east-005

# ─── Cloudflare (CDN Cache Purge) ───────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ─── Sentry (Error Monitoring) ──────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=bossboard
SENTRY_PROJECT=bossboard-web

# ─── Cron Jobs ──────────────────────────────────────────────
# Secret used to authenticate Vercel cron requests
CRON_SECRET=
